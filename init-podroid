#!/bin/sh
# Podroid init — persistent Alpine Linux VM with Podman
# Two-phase: Phase 1 mounts the overlay, Phase 2 runs the main system.

# ── Phase 2: Main init (running inside persistent overlay) ──────────────────
if [ "$1" = "--main" ]; then

# ── Core filesystems ────────────────────────────────────────────────────────
mount -t proc proc /proc -o noexec,nosuid,nodev
mount -t sysfs sys /sys -o noexec,nosuid,nodev
mount -t devtmpfs devtmpfs /dev -o exec,nosuid,mode=0755,size=2M 2>/dev/null || \
    mount -t tmpfs tmpfs /dev -o exec,nosuid,mode=0755,size=2M
mkdir -p /dev/pts /dev/shm /dev/mqueue /dev/net
mount -t devpts devpts /dev/pts -o gid=5,mode=0620,noexec,nosuid 2>/dev/null
mount -t tmpfs tmpfs /dev/shm  -o noexec,nosuid,nodev,size=64m
mount -t tmpfs tmpfs /tmp      -o noexec,nosuid,nodev
mount -t tmpfs tmpfs /run      -o noexec,nosuid,nodev,mode=0755

# ── cgroup2 ─────────────────────────────────────────────────────────────────
mkdir -p /sys/fs/cgroup
mount -t cgroup2 cgroup2 /sys/fs/cgroup 2>/dev/null
if [ -f /sys/fs/cgroup/cgroup.subtree_control ]; then
    for ctrl in cpuset cpu io memory hugetlb pids rdma misc; do
        echo "+$ctrl" > /sys/fs/cgroup/cgroup.subtree_control 2>/dev/null
    done
fi

# ── Busybox + dirs ──────────────────────────────────────────────────────────
/bin/busybox --install -s 2>/dev/null
mkdir -p /var/lib/containers/storage /var/log /var/tmp /root
mkdir -p /run/lock /run/containers/storage /run/libpod
chmod 700 /root
chmod 1777 /tmp /var/tmp

# ── Hostname ─────────────────────────────────────────────────────────────────
echo "podroid" > /etc/hostname
hostname podroid

# ── Kernel modules ───────────────────────────────────────────────────────────
echo "[init] Loading kernel modules..."
KVER=$(uname -r)
if [ -d "/lib/modules/$KVER" ]; then
    depmod -a 2>/dev/null
    for mod in virtio_net virtio_blk fuse tun veth bridge br_netfilter overlay \
               xt_addrtype xt_conntrack xt_nat nf_nat nf_conntrack ip_tables \
               9p 9pnet 9pnet_virtio; do
        modprobe $mod 2>/dev/null
    done
fi
[ ! -c /dev/net/tun ] && mknod /dev/net/tun c 10 200 2>/dev/null

# ── Read kernel cmdline params ───────────────────────────────────────────────
ANDROID_IP="unknown"
SSH_ENABLED=0
for param in $(cat /proc/cmdline); do
    case "$param" in
        androidip=*) ANDROID_IP="${param#androidip=}" ;;
        ssh=1)       SSH_ENABLED=1 ;;
    esac
done

# ── Networking ───────────────────────────────────────────────────────────────
echo "[init] Waiting for network..."
NETIF=""
for i in $(seq 1 30); do
    NETIF=$(ip -o link show 2>/dev/null | awk -F': ' '{print $2}' | grep -v lo | head -1)
    [ -n "$NETIF" ] && break
    sleep 1
done

if [ -n "$NETIF" ]; then
    echo "[init] Found: $NETIF"
    ip link set dev "$NETIF" up
    ip addr add 10.0.2.15/24 dev "$NETIF" 2>/dev/null
    ip route add default via 10.0.2.2 dev "$NETIF" 2>/dev/null
else
    echo "[init] WARNING: No network interface found!"
fi

echo "nameserver 10.0.2.3" > /etc/resolv.conf
echo "nameserver 8.8.8.8"  >> /etc/resolv.conf
echo "nameserver 1.1.1.1"  >> /etc/resolv.conf

# ── Downloads folder ─────────────────────────────────────────────────────────
# msize=1048576: 1MB message size instead of the default 8KB — reduces round-trips
#   128x for large files (400MB = 400 trips instead of 51200)
# cache=loose: guest page-caches data already read; reads the same file twice
#   without going back to the host
# noatime: skip access time writes on every read
mkdir -p /mnt/downloads
if mount -t 9p -o trans=virtio,version=9p2000.L,rw,msize=1048576,cache=loose,noatime downloads /mnt/downloads 2>/dev/null; then
    echo "[init] Downloads folder mounted at /mnt/downloads"
fi

# ── Container config ─────────────────────────────────────────────────────────
echo "[init] Configuring containers..."
sysctl -qw net.ipv4.ip_forward=1 2>/dev/null
sysctl -qw net.ipv4.conf.all.forwarding=1 2>/dev/null
sysctl -qw net.bridge.bridge-nf-call-iptables=1 2>/dev/null
sysctl -qw net.bridge.bridge-nf-call-ip6tables=1 2>/dev/null
sysctl -qw net.ipv4.ping_group_range="0 2147483647" 2>/dev/null
sysctl -qw kernel.unprivileged_userns_clone=1 2>/dev/null
sysctl -qw fs.inotify.max_user_instances=256 2>/dev/null
sysctl -qw fs.inotify.max_user_watches=65536 2>/dev/null

[ -f /etc/subuid ] || echo "root:100000:65536" > /etc/subuid
[ -f /etc/subgid ] || echo "root:100000:65536" > /etc/subgid

if [ ! -f /etc/containers/containers.conf ]; then
    mkdir -p /etc/containers
    cat > /etc/containers/containers.conf <<'CONF'
[containers]
cgroups = "enabled"
default_sysctls = []
userns = "host"

[engine]
runtime = "crun"
no_pivot_root = true
network_cmd = "/usr/bin/slirp4netns"
events_logger = "file"

[network]
network_backend = "netavark"
CONF

    cat > /etc/containers/storage.conf <<'CONF'
[storage]
driver = "overlay"
runroot = "/run/containers/storage"
graphroot = "/var/lib/containers/storage"

[storage.options.overlay]
mount_program = "/usr/bin/fuse-overlayfs"
CONF

    cat > /etc/containers/registries.conf <<'CONF'
unqualified-search-registries = ["docker.io", "quay.io"]
CONF
fi

if [ ! -f /etc/crun/crun.conf ]; then
    mkdir -p /etc/crun
    cat > /etc/crun/crun.conf <<'CONF'
[global]
no-pivot = true
CONF
fi

# ── SSH setup (Dropbear) ─────────────────────────────────────────────────────
if [ "$SSH_ENABLED" = "1" ]; then
    echo "[init] Starting SSH server (Dropbear)..."

    if [ ! -f /etc/podroid-ssh-init ]; then
        echo "root:podroid" | chpasswd 2>/dev/null
        touch /etc/podroid-ssh-init
    fi

    mkdir -p /etc/dropbear
    if [ ! -f /etc/dropbear/dropbear_rsa_host_key ]; then
        dropbearkey -t rsa -f /etc/dropbear/dropbear_rsa_host_key >/dev/null 2>&1
    fi

    mkdir -p /root/.ssh
    chmod 700 /root/.ssh

    if dropbear -p 22; then
        echo "[init] SSH server started on port 22 (host port 9922)"
    else
        echo "[init] WARNING: SSH server failed to start"
    fi
fi

# ── Environment ──────────────────────────────────────────────────────────────
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
export HOME=/root
export TERM=xterm-256color
export LANG=C.UTF-8
export LC_ALL=C.UTF-8
export CHARSET=UTF-8
export PODMAN_IGNORE_CGROUPSV1_WARNING=1
export CONTAINERS_CONF=/etc/containers/containers.conf
export CONTAINERS_STORAGE_CONF=/etc/containers/storage.conf
export CONTAINERS_REGISTRIES_CONF=/etc/containers/registries.conf

# ── Console settings ─────────────────────────────────────────────────────────
dmesg -n 1 2>/dev/null
stty rows 24 cols 80 -ixon -ixoff -iexten 2>/dev/null

# ── Shutdown handler ─────────────────────────────────────────────────────────
shutdown_handler() {
    echo ""
    echo "[init] Shutting down..."
    sync
    podman stop -a -t 5 2>/dev/null
    sync
    echo "[init] Goodbye."
}
trap shutdown_handler TERM INT HUP

# ── Internet check ───────────────────────────────────────────────────────────
INTERNET="no"
if wget -q -O /dev/null --timeout=5 http://dl-cdn.alpinelinux.org/alpine/MIRRORS.txt 2>/dev/null; then
    INTERNET="yes"
fi

# ── MOTD ─────────────────────────────────────────────────────────────────────
VM_IP=$(ip addr show "$NETIF" 2>/dev/null | grep 'inet ' | awk '{print $2}' | cut -d'/' -f1)
STORAGE_GB=$(df -BG / 2>/dev/null | awk 'NR==2 {gsub(/G/,"",$2); print $2}')

SSH_LINE=""
if [ "$SSH_ENABLED" = "1" ]; then
    SSH_LINE="  ssh root@${ANDROID_IP} -p 9922  (pass: podroid, dropbear)"
fi

cat > /etc/motd <<MOTD

  ____          _              _     _
 |  _ \ ___  __| |_ __ ___ (_) __| |
 | |_) / _ \/ _\` | '__/ _ \| |/ _\` |
 |  __/ (_) | (_| | | | (_) | | (_| |
 |_|   \___/ \__,_|_|  \___/|_|\__,_|

  Alpine 3.23  ·  Podman  ·  QEMU

  ip ${VM_IP:-10.0.2.15}  ·  internet ${INTERNET}  ·  storage ${STORAGE_GB:-?} GB
${SSH_LINE}

  podman run --rm -it alpine sh
  podman run -d -p 8080:80 nginx

MOTD

# ── Profile ───────────────────────────────────────────────────────────────────
cat > /etc/profile <<'PROF'
export HOME=/root
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
export TERM=xterm-256color
export LANG=C.UTF-8
export LC_ALL=C.UTF-8
export CHARSET=UTF-8
export PODMAN_IGNORE_CGROUPSV1_WARNING=1
export CONTAINERS_CONF=/etc/containers/containers.conf
export CONTAINERS_STORAGE_CONF=/etc/containers/storage.conf
export CONTAINERS_REGISTRIES_CONF=/etc/containers/registries.conf
stty -ixon -ixoff -iexten -echoctl 2>/dev/null
cd /root
PROF

# ── Resize control daemon ─────────────────────────────────────────────────────
# Reads "RESIZE rows cols\n" from /dev/hvc0 (virtio-console, mapped from
# ctrl.sock on the Android side by podroid-bridge on SIGWINCH).
# stty on /dev/ttyAMA0 calls TIOCSWINSZ; the Linux kernel automatically
# sends SIGWINCH to the foreground process group — nvim/htop/btop resize
# correctly without any stdin injection.
(
    for i in $(seq 1 30); do
        [ -c /dev/hvc0 ] && break
        sleep 1
    done
    [ -c /dev/hvc0 ] || exit 0
    while IFS= read -r line; do
        case "$line" in
            RESIZE\ *)
                set -- $line
                stty rows "$2" cols "$3" < /dev/ttyAMA0 2>/dev/null
                ;;
        esac
    done < /dev/hvc0
) &

# ── Login wrapper ─────────────────────────────────────────────────────────────
cat > /usr/local/bin/podroid-login <<'LOGIN'
#!/bin/sh
. /etc/profile
cat /etc/motd
exec /bin/sh
LOGIN
chmod +x /usr/local/bin/podroid-login

grep -q '^root:' /etc/passwd 2>/dev/null || echo "root:x:0:0:root:/root:/bin/sh" > /etc/passwd

while true; do
    /sbin/getty -n -l /usr/local/bin/podroid-login 0 ttyAMA0 xterm-256color
    sleep 1
done
fi

# ══════════════════════════════════════════════════════════════════════════════
# Phase 1: Early init — mount persistent storage and pivot to overlay
# ══════════════════════════════════════════════════════════════════════════════

mount -t proc proc /proc -o noexec,nosuid,nodev
mount -t sysfs sys /sys -o noexec,nosuid,nodev
mount -t devtmpfs devtmpfs /dev -o exec,nosuid,mode=0755,size=2M 2>/dev/null || \
    mount -t tmpfs tmpfs /dev -o exec,nosuid,mode=0755,size=2M

KVER=$(uname -r)
if [ -d "/lib/modules/$KVER" ]; then
    depmod -a 2>/dev/null
    modprobe virtio_blk 2>/dev/null
fi

echo 1 > /proc/sys/kernel/printk 2>/dev/null

mkdir -p /mnt/persist
PERSIST_DEV=""
for dev in /dev/vda /dev/vdb; do
    [ -b "$dev" ] || continue
    PERSIST_DEV="$dev"
    break
done

OVERLAY_OK=false
if [ -n "$PERSIST_DEV" ]; then
    if ! mount -t ext4 -o rw,noatime "$PERSIST_DEV" /mnt/persist 2>/dev/null; then
        /bin/busybox --install -s 2>/dev/null
        e2fsck -y "$PERSIST_DEV" >/dev/null 2>&1
        if ! mount -t ext4 -o rw,noatime "$PERSIST_DEV" /mnt/persist 2>/dev/null; then
            echo "[init] Formatting $PERSIST_DEV for persistent storage..."
            mkfs.ext4 -q -F "$PERSIST_DEV" >/dev/null 2>&1
            mount -t ext4 -o rw,noatime "$PERSIST_DEV" /mnt/persist 2>/dev/null
        fi
    fi

    if mountpoint -q /mnt/persist 2>/dev/null; then
        mkdir -p /mnt/persist/upper /mnt/persist/work /mnt/overlay

        mount -t overlay overlay \
            -o lowerdir=/,upperdir=/mnt/persist/upper,workdir=/mnt/persist/work \
            /mnt/overlay 2>/dev/null

        if mountpoint -q /mnt/overlay 2>/dev/null; then
            mkdir -p /mnt/overlay/mnt/persist
            mount --bind /mnt/persist /mnt/overlay/mnt/persist
            touch /mnt/persist/.overlay-active
            umount /dev 2>/dev/null
            umount /sys 2>/dev/null
            umount /proc 2>/dev/null
            exec chroot /mnt/overlay /init --main
        else
            echo "[init] WARNING: Overlay mount failed! Running without persistence."
        fi
    fi
fi

echo "[init] WARNING: No persistent storage — changes will be lost on reboot!"
umount /dev 2>/dev/null
umount /sys 2>/dev/null
umount /proc 2>/dev/null
exec /init --main
